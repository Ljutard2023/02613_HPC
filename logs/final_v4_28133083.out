from os.path import join
from part3_numba import jacobi_numba
from simulate import load_data, summary_stats

LOAD_DIR = '/dtu/projects/02613_2025/data/modified_swiss_dwellings/'
MAX_ITER, ABS_TOL = 20_000, 1e-4

# Charger tous les IDs
with open(join(LOAD_DIR, 'building_ids.txt')) as f:
    all_ids = f.read().splitlines()

# Charger les IDs déjà traités
done = set()
with open('logs/final_v3_28123591.out') as f:
    for line in f:
        if ',' in line and line[0].isdigit():
            done.add(line.split(',')[0].strip())

remaining = [bid for bid in all_ids if bid not in done]
print(f"Déjà traités : {len(done)}", flush=True)
print(f"Restants     : {len(remaining)}", flush=True)

# Warm-up JIT
u0, mask = load_data(LOAD_DIR, remaining[0])
_ = jacobi_numba(u0.copy(), mask, max_iter=1)
print("Warm-up OK", flush=True)

stat_keys = ['mean_temp','std_temp','pct_above_18','pct_below_15']
print('building_id,' + ','.join(stat_keys))
for bid in remaining:
    u0, mask = load_data(LOAD_DIR, bid)
    u = jacobi_numba(u0.copy(), mask, MAX_ITER, ABS_TOL)
    s = summary_stats(u, mask)
    print(f"{bid}," + ",".join(str(s[k]) for k in stat_keys), flush=True)
PYEOF

