from os.path import join
import numpy as np
from part3_numba import jacobi_numba_parallel
from simulate import load_data, summary_stats

LOAD_DIR = '/dtu/projects/02613_2025/data/modified_swiss_dwellings/'
MAX_ITER = 20_000
ABS_TOL  = 1e-4

with open(join(LOAD_DIR, 'building_ids.txt')) as f:
    building_ids = f.read().splitlines()

# Warm-up
u0, mask = load_data(LOAD_DIR, building_ids[0])
_ = jacobi_numba_parallel(u0.copy(), mask, max_iter=1)
print("Warm-up OK", flush=True)

# Traitement de tous les bâtiments
stat_keys = ['mean_temp', 'std_temp', 'pct_above_18', 'pct_below_15']
print('building_id,' + ','.join(stat_keys))
for bid in building_ids:
    u0, mask = load_data(LOAD_DIR, bid)
    u = jacobi_numba_parallel(u0.copy(), mask, MAX_ITER, ABS_TOL)
    s = summary_stats(u, mask)
    print(f"{bid}," + ",".join(str(s[k]) for k in stat_keys), flush=True)
